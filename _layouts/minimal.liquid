<!doctype html>
<html lang="{{ site.lang | default: 'en' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>
      {% if page.permalink == "/" %}
        {{ site.title }}
      {% else %}
        {{ page.title | capitalize }} | {{ site.title }}
      {% endif %}
    </title>
    <meta name="description" content="{{ site.description | strip_html | strip }}">
    <style>
      :root {
        color-scheme: light dark;
        --bg: #ffffff;
        --fg: #111111;
        --muted: #686868;
        --line: #e8e8e8;
        --link: #1f5fbf;
        --link-hover: #0b3f8a;
        --max: 680px;
      }

      html[data-theme="dark"] {
        --bg: #111111;
        --fg: #eeeeee;
        --muted: #a6a6a6;
        --line: #2b2b2b;
        --link: #8ab4f8;
        --link-hover: #b7d1ff;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
        font-size: 16px;
        line-height: 1.65;
      }

      a {
        color: var(--link);
        text-decoration: none;
      }

      a:hover {
        color: var(--link-hover);
        text-decoration: underline;
      }

      .site {
        width: min(var(--max), calc(100% - 32px));
        margin: 0 auto;
        padding: 32px 0 44px;
      }

      .theme-toggle {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-bottom: 18px;
        color: var(--muted);
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
      }

      .theme-toggle button {
        padding: 0;
        border: 0;
        background: transparent;
        color: inherit;
        font: inherit;
        cursor: pointer;
      }

      .theme-toggle button[aria-pressed="true"] {
        color: var(--fg);
      }

      .site-title {
        margin: 0 0 12px;
        text-align: center;
        font-size: 22px;
        font-weight: 650;
        line-height: 1.2;
      }

      .site-title a {
        color: var(--fg);
      }

      .nav {
        display: flex;
        justify-content: center;
        gap: 18px;
        margin-bottom: 38px;
        font-size: 14px;
      }

      .nav a {
        color: var(--fg);
      }

      .nav a.active {
        font-weight: 650;
      }

      main {
        width: 100%;
      }

      .home-photo {
        width: 132px;
        height: 132px;
        margin: 0 auto 30px;
        border-radius: 50%;
        border: 1px solid var(--line);
        background:
          radial-gradient(circle at 50% 36%, var(--bg) 0 26px, transparent 27px),
          radial-gradient(circle at 50% 98%, var(--bg) 0 55px, transparent 56px),
          linear-gradient(135deg, #d8d8d8, #777777);
      }

      h1,
      h2,
      h3,
      h4 {
        color: var(--fg);
        line-height: 1.25;
      }

      h1 {
        margin: 0 0 18px;
        text-align: center;
        font-size: 24px;
        font-weight: 650;
      }

      h2 {
        margin: 38px 0 14px;
        font-size: 22px;
        font-weight: 650;
      }

      h3 {
        margin: 28px 0 10px;
        font-size: 18px;
        font-weight: 650;
      }

      h4 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
      }

      p {
        margin: 0 0 16px;
      }

      ul,
      ol {
        padding-left: 20px;
      }

      .intro {
        text-align: left;
      }

      .links {
        margin: 22px 0 30px;
        text-align: center;
        color: var(--muted);
        font-size: 14px;
      }

      .links a {
        margin: 0 6px;
        white-space: nowrap;
      }

      .news-list {
        display: grid;
        gap: 16px;
        margin-top: 14px;
      }

      .news-item {
        display: grid;
        grid-template-columns: 88px 1fr;
        gap: 18px;
        align-items: baseline;
      }

      .news-date {
        color: var(--muted);
        font-size: 13px;
        white-space: nowrap;
      }

      .news-text p {
        margin-bottom: 0;
      }

      .publications {
        margin-top: 22px;
      }

      .bibliography {
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .bibliography li {
        margin: 0 0 22px;
        padding-bottom: 22px;
        border-bottom: 1px solid var(--line);
      }

      .bibliography .title {
        color: var(--fg);
        font-weight: 650;
      }

      .bibliography .author,
      .bibliography .periodical,
      .bibliography .links,
      .bibliography .abstract,
      .bibliography .award,
      .bibliography .annotation {
        color: var(--muted);
        font-size: 14px;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th,
      td {
        padding: 8px 0;
        border-bottom: 1px solid var(--line);
        text-align: left;
        vertical-align: top;
      }

      footer {
        margin-top: 48px;
        padding-top: 22px;
        border-top: 1px solid var(--line);
        color: var(--muted);
        text-align: center;
        font-size: 13px;
      }

      @media (max-width: 560px) {
        .site {
          width: min(100% - 26px, var(--max));
          padding-top: 24px;
        }

        .nav {
          gap: 13px;
          margin-bottom: 30px;
        }

        .home-photo {
          width: 112px;
          height: 112px;
        }

        .news-item {
          grid-template-columns: 1fr;
          gap: 2px;
        }
      }
    </style>
    <script>
      (function () {
        var saved = localStorage.getItem("theme");
        var theme = saved || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <div class="site">
      <div class="theme-toggle" aria-label="Theme">
        <button type="button" data-theme-choice="light">LIGHT</button>
        <button type="button" data-theme-choice="dark">DARK</button>
      </div>

      <header>
        <p class="site-title"><a href="{{ '/' | relative_url }}">{{ site.title }}</a></p>
        <nav class="nav" aria-label="Main navigation">
          {% assign nav_pages = site.pages | where_exp: "item", "item.nav == true" | sort: "nav_order" %}
          {% for nav_page in nav_pages %}
            <a
              href="{{ nav_page.url | relative_url }}"
              {% if page.url == nav_page.url %}class="active"{% endif %}
            >
              {{ nav_page.nav_title | default: nav_page.title | capitalize }}
            </a>
          {% endfor %}
        </nav>
      </header>

      <main>
        {{ content }}
      </main>

      <footer>
        {{ site.footer_text }}
      </footer>
    </div>

    <script>
      (function () {
        var current = document.documentElement.getAttribute("data-theme");
        var buttons = document.querySelectorAll("[data-theme-choice]");
        function setTheme(theme) {
          document.documentElement.setAttribute("data-theme", theme);
          localStorage.setItem("theme", theme);
          buttons.forEach(function (button) {
            button.setAttribute("aria-pressed", String(button.dataset.themeChoice === theme));
          });
        }
        buttons.forEach(function (button) {
          button.addEventListener("click", function () {
            setTheme(button.dataset.themeChoice);
          });
        });
        setTheme(current);
      })();
    </script>
  </body>
</html>
